rules_version = '2';
service cloud.firestore {
  function signedIn() {
    return request.auth != null;
  }

  function participantByUid(data) {
    return signedIn() && request.auth.uid in data.participantUids;
  }

  function participantByEmail(data) {
    return signedIn() &&
      request.auth.token.email != null &&
      request.auth.token.email in data.participantEmails;
  }

  match /databases/{database}/documents {
    match /userDirectory/{uid} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == uid;
    }

    match /users/{uid}/settings/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /users/{uid}/syncSnapshots/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /sharedObligations/{docId} {
      allow create: if signedIn() &&
        request.resource.data.createdByUid == request.auth.uid &&
        request.auth.uid in request.resource.data.participantUids;
      allow read: if participantByUid(resource.data) || participantByEmail(resource.data);
      allow update: if participantByUid(resource.data) || participantByEmail(resource.data);
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
